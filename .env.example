# ============================================
# THE BOX OFFICE SCIENCE — Environment Config
# ============================================

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME="The Box Office Science"

# --- Backend ---
# Local Mongo (docker-compose) or a MongoDB Atlas connection string.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=boxoffice
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALLOWED_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
DEBUG=false

# --- External APIs ---
# TMDb API Key → https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# OMDb API Key (optional, for IMDb ratings) → http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# --- AI / ML (optional future use) ---
OPENAI_API_KEY=
HUGGINGFACE_TOKEN=
